{
  "manifest_version": 3,
  "name": "JPI API Inspector",
  "version": "1.0.0",
  "description": "Inspect Prod and Dev API responses for JPI newspaper sites",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://jpi-api-prod.brightsites.co.uk/*",
    "https://jpi-api-dev.brightsites.co.uk/*",
    "https://*.brightsites.co.uk/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
